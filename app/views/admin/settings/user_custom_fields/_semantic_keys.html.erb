<%= settings_primer_form_with(
      url: semantic_keys_admin_settings_user_custom_fields_path,
      method: :patch,
      data: { turbo: false }
    ) do %>
  <%= render(Primer::Beta::Text.new(tag: :p, color: :muted, mb: 3)) do
        t("settings.user_custom_fields.semantic_keys.description")
      end %>

  <% UserCustomField.semantic_keys.each_key do |key| %>
    <%= render(
          Primer::Alpha::Select.new(
            name: "semantic_keys[#{key}]",
            label: t("custom_fields.semantic_keys.#{key}"),
            caption: t("settings.user_custom_fields.semantic_keys.descriptions.#{key}", default: ""),
            input_width: :large,
            data: { test_selector: "semantic-key-#{key}" }
          )
        ) do |select| %>
      <% select.option(value: "", label: t("custom_fields.semantic_keys.none")) %>
      <% @semantic_key_field_options.each do |custom_field| %>
        <% select.option(
             value: custom_field.id,
             label: custom_field.name,
             selected: @semantic_key_assignments[key]&.id == custom_field.id
           ) %>
      <% end %>
    <% end %>
  <% end %>

  <%= render(Primer::Beta::Button.new(type: :submit, scheme: :primary, mt: 2)) { t(:button_save) } %>
<% end %>
