<%= flex_layout do |box|
  box.with_row do
    flex_layout do |row|
      row.with_column(flex: 1) do
        concat(render(Primer::Beta::Text.new(font_weight: :semibold, tag: :div)) {
          I18n.t(:"admin.jira.run.wizard.sections.fetch_data.title")
        })
        if import_run.status_equal_or_after?(JiraImport::INSTANCE_META_DONE)
          concat(render(Primer::Beta::Text.new(font_size: :small, color: :subtle)) {
            I18n.t(:"admin.jira.run.wizard.sections.fetch_data.caption_done")
          })
        end
      end
      if import_run.status?(JiraImport::INSTANCE_META_DONE, JiraImport::CONFIGURING)
        row.with_column do
          render(
            Primer::Beta::IconButton.new(
              icon: :"op-reload",
              tag: :a,
              scheme: :invisible,
              href: continue_admin_import_jira_run_path(jira_id: import_run.jira.id, id: import_run.id, step: 'fetch'),
              aria: { label: "Back to fetch data" },
              data: { turbo_stream: true }
            )
          )
        end
      end
    end
  end
  if import_run.status?(JiraImport::INITIAL)
    box.with_row(mb: 3) do
      render(Primer::Beta::Text.new) {
        I18n.t(:"admin.jira.run.wizard.sections.fetch_data.description")
      }
    end
    box.with_row do
      render(Primer::Beta::Button.new(
        scheme: :primary,
        tag: :a,
        size: :medium,
        href: continue_admin_import_jira_run_path(jira_id: import_run.jira.id, id: import_run.id, step: 'fetch'),
        data: { turbo_stream: true }
      )) do
        I18n.t(:"admin.jira.run.wizard.sections.fetch_data.button_fetch")
      end
    end
  elsif import_run.status?(JiraImport::INSTANCE_META_ERROR)
    box.with_row(mt: 3) do
      render(Admin::Import::Jira::ImportRuns::ErrorBannerComponent.new(import_run, 'fetch'))
    end
  elsif import_run.status?(JiraImport::INSTANCE_META_FETCHING)
    box.with_row(mt: 3) do
      render(Admin::Import::Jira::ImportRuns::ProgressBoxComponent.new(
        I18n.t(:"admin.jira.run.wizard.sections.fetch_data.label_progress")
      ))
    end
  end
end %>
