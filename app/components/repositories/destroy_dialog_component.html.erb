<%=
  render(
    Primer::OpenProject::DangerDialog.new(
      id:,
      title: dialog_title,
      size: :large,
      **(@repository.managed? ? {} : { confirm_button_text: t(:button_remove) }),
      form_arguments: {
        action: project_repository_path(@project),
        method: :delete,
        data: { turbo: false }
      }
    )
  ) do |dialog|
    dialog.with_confirmation_message(**(@repository.managed? ? { icon_arguments: { icon: :trash } } : {})) do |message|
      message.with_heading(tag: :h2) { dialog_heading }
      message.with_description do
        if @repository.managed?
          content_tag(
            :p, t(
              "repositories.destroy_dialog.description",
              repository_type: repository_label,
              path: @repository.root_url
            )
          )
        else
          content_tag(
            :p, t(
              "repositories.destroy_dialog.description_not_managed",
              repository_type: repository_label,
              url: @repository.url
            )
          )
        end
      end
    end

    dialog.with_confirmation_check_box_content(I18n.t(:text_permanent_delete_confirmation_checkbox_label)) if @repository.managed?
  end
%>
