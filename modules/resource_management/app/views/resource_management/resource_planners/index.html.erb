<% html_title t(:label_resource_management) %>

<%= render(ResourcePlanners::IndexPageHeaderComponent.new(project: @project)) %>
<%= render(ResourcePlanners::IndexSubHeaderComponent.new(project: @project)) %>

<% if @resource_planners.any? %>
  <%= render(ResourcePlanners::TableComponent.new(rows: @resource_planners, current_project: @project)) %>
<% else %>
  <%= render(Primer::Beta::Blankslate.new) do |blankslate|
        blankslate.with_visual_icon(icon: :people)
        blankslate.with_heading(tag: :h2) { t("resource_management.blankslate.title") }
        blankslate.with_description { t("resource_management.blankslate.desc") }
      end %>
<% end %>
