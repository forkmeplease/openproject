<%= render(Primer::OpenProject::PageHeader.new) do |header|
      header.with_title { @resource_planner.name }
      header.with_breadcrumbs(breadcrumb_items)

      if favorited?
        header.with_action_icon_button(
          icon: "star-fill",
          mobile_icon: "star-fill",
          label: t(:button_unfavorite),
          classes: "op-primer--star-icon",
          tag: :a,
          href: favorite_path_for(@resource_planner),
          data: { turbo_method: :delete, "test-selector": "resource-planner-unfavorite" }
        )
      else
        header.with_action_icon_button(
          icon: "star",
          mobile_icon: "star",
          label: t(:button_favorite),
          tag: :a,
          href: favorite_path_for(@resource_planner),
          data: { turbo_method: :post, "test-selector": "resource-planner-favorite" }
        )
      end

      if show_action_menu?
        header.with_action_menu(
          menu_arguments: { anchor_align: :end },
          button_arguments: { icon: "kebab-horizontal", "aria-label": t(:label_more) }
        ) do |menu|
          if edit_allowed?
            menu.with_item(
              label: t(:button_edit),
              tag: :a,
              href: edit_project_resource_planner_path(@project, @resource_planner),
              content_arguments: { data: { controller: "async-dialog", "test-selector": "resource-planner-edit" } }
            ) do |item|
              item.with_leading_visual_icon(icon: :pencil)
            end
          end

          if delete_allowed?
            menu.with_item(
              label: t(:button_delete),
              scheme: :danger,
              tag: :a,
              href: project_resource_planner_path(@project, @resource_planner),
              content_arguments: {
                data: {
                  turbo_method: :delete,
                  turbo_confirm: t(:text_are_you_sure),
                  "test-selector": "resource-planner-delete"
                }
              }
            ) do |item|
              item.with_leading_visual_icon(icon: :trash)
            end
          end
        end
      end
    end %>
