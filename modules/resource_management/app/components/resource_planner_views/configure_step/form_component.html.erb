<%=
  component_wrapper do
    content_tag(:div, data: { controller: "show-when-value-selected" }) do
      primer_form_with(
        model: @view,
        scope: :view,
        url: @url,
        method: @method,
        html: {
          data: { turbo_stream: true },
          id: @form_id
        }
      ) do |f|
        flex_layout do |body|
          if @view.errors[:base].present?
            body.with_row(mb: 3) do
              render(Primer::Alpha::Banner.new(mb: 3, icon: :stop, scheme: :danger)) { @view.errors[:base].join("\n") }
            end
          end

          @hidden_fields.each do |name, value|
            body.with_row do
              concat(hidden_field_tag(name, value))
            end
          end

          body.with_row do
            render(ResourcePlannerViews::Forms::ConfigureForm.new(f))
          end

          if show_card_fields?
            body.with_row(mt: 3) do
              helpers.angular_component_tag(
                "opce-draggable-autocompleter",
                inputs: {
                  options: card_field_options,
                  selected: selected_card_fields,
                  name: "card_fields",
                  id: "resource-user-card-fields",
                  dragAreaName: "resource-user-card-fields_dragarea",
                  formControlId: "resource-user-card-fields_autocompleter",
                  inputLabel: t("resource_management.user_card_list.fields.input_label"),
                  inputCaption: t("resource_management.user_card_list.fields.input_caption"),
                  inputPlaceholder: t("resource_management.user_card_list.fields.input_placeholder"),
                  dragAreaLabel: t("resource_management.user_card_list.fields.drag_area_label"),
                  appendToComponent: true
                }
              )
            end
          end

          if has_filter_query?
            body.with_row(
              mt: 3,
              data: {
                target_name: "filter_mode",
                value: "automatic",
                "show-when-value-selected-target": "effect"
              },
              hidden: !initial_filter_mode_automatic?
            ) do
              render(
                ::Filters::FilterFormComponent.new(
                  builder: f,
                  query: @filter_query,
                  wrap_with_controller: true,
                  hidden_input_name: "filters",
                  output_format: :json,
                  autocomplete_append_to: "##{@dialog_id}"
                )
              )
            end
          end
        end
      end
    end
  end
%>
