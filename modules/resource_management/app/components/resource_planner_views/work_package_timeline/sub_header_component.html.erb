<%=
  render(Primer::OpenProject::SubHeader.new) do |subheader|
    subheader.with_action_button(
      tag: :button,
      leading_icon: :calendar,
      label: t("resource_management.work_package_timeline.navigation.today"),
      data: nav_action("today")
    ) { t("resource_management.work_package_timeline.navigation.today") }

    subheader.with_action_button(
      icon_only: true,
      leading_icon: :"chevron-left",
      label: t("resource_management.work_package_timeline.navigation.previous"),
      tag: :button,
      data: nav_action("prev")
    )

    subheader.with_action_button(
      icon_only: true,
      leading_icon: :"chevron-right",
      label: t("resource_management.work_package_timeline.navigation.next"),
      tag: :button,
      data: nav_action("next")
    )

    subheader.with_action_menu(
      leading_icon: :clock,
      trailing_icon: :"triangle-down",
      label: granularity_label(:week),
      button_arguments: { "aria-label": granularity_label(:week) }
    ) do |menu|
      GRANULARITIES.each do |key, view_name|
        menu.with_item(
          label: granularity_label(key),
          tag: :button,
          content_arguments: { data: granularity_action(view_name) }
        ) { granularity_label(key) }
      end
    end

    if allowed_to_allocate?
      subheader.with_action_button(
        leading_icon: :plus,
        scheme: :primary,
        label: t("resource_management.work_package_list.subheader.allocate"),
        tag: :a,
        href: new_project_resource_allocation_path(@project),
        data: { controller: "async-dialog" }
      ) { t("resource_management.work_package_list.subheader.allocate") }
    end
  end
%>
