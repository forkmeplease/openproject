<%= render(
      ResourcePlannerViews::UserCardList::SubHeaderComponent.new(
        project: @project,
        resource_planner: @resource_planner,
        view: @view
      )
    ) %>

<% if users.empty? %>
  <%= render(Primer::Beta::Blankslate.new) do |blankslate|
        blankslate.with_visual_icon(icon: :people)
        blankslate.with_heading(tag: :h2) { t("resource_management.user_card_list.blank.title") }
        blankslate.with_description { blank_description }
      end %>
<% else %>
  <%= render(Primer::Box.new(classes: "op-user-card-list")) do %>
    <% users.each do |user| %>
      <%= render(
            ResourcePlannerViews::UserCardList::CardComponent.new(
              user:,
              remove_path: remove_path_for(user),
              utilization: utilization_for(user),
              details_path: details_path_for(user)
            )
          ) %>
    <% end %>
  <% end %>
<% end %>
