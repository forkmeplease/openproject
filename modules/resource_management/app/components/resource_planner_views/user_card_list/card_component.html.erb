<%=
  flex_layout(classes: "op-user-card", data: { test_selector: "user-card-#{@user.id}" }) do |card|
    card.with_row do
      flex_layout(classes: "op-user-card--header", align_items: :center) do |header|
        header.with_column do
          render(Users::AvatarComponent.new(user: @user, show_name: false, link: false, hover_card: { active: false }))
        end

        header.with_column(classes: "op-user-card--identity") do
          flex_layout do |identity|
            identity.with_row(classes: "op-user-card--name") do
              render(Primer::Beta::Text.new(font_weight: :semibold, data: { test_selector: "user-card-name" })) do
                @user.name
              end
            end

            if show_email?
              identity.with_row(classes: "op-user-card--email") do
                render(
                  Primer::Beta::Text.new(
                    font_size: :small,
                    color: :muted,
                    data: { test_selector: "user-card-email" }
                  )
                ) do
                  @user.mail
                end
              end
            end
          end
        end

        if @remove_path
          header.with_column do
            render(
              Primer::Beta::IconButton.new(
                icon: :trash,
                scheme: :danger,
                tag: :a,
                href: @remove_path,
                label: t("resource_management.user_card_list.card.remove"),
                aria: { label: t("resource_management.user_card_list.card.remove") },
                data: {
                  turbo_method: :delete,
                  turbo_confirm: t("resource_management.user_card_list.card.remove_confirmation"),
                  test_selector: "user-card-remove-#{@user.id}"
                }
              )
            )
          end
        end
      end
    end

    card.with_row do
      flex_layout(classes: "op-user-card--group-list", align_items: :center) do |f|
        f.with_column do
          render(Primer::Beta::Octicon.new(icon: :people))
        end

        f.with_column do
          render(Primer::Beta::Text.new(color: :muted, data: { test_selector: "user-card-groups" })) do
            group_membership_summary
          end
        end
      end
    end

    card.with_row do
      render(
        Primer::Beta::Button.new(
          tag: :a,
          href: helpers.allowed_management_user_profile_path(@user),
          data: { test_selector: "user-card-profile-btn" }
        )
      ) do
        I18n.t("users.open_profile")
      end
    end
  end
%>
