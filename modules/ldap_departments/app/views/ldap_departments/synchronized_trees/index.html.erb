<% html_title(t(:label_administration), t("ldap_departments.synchronized_trees.plural")) -%>

<%=
  render Primer::OpenProject::PageHeader.new do |header|
    header.with_title { I18n.t("ldap_departments.synchronized_trees.plural") }
    header.with_breadcrumbs(
      [{ href: admin_index_path, text: t(:label_administration) },
       { href: admin_settings_authentication_path, text: t(:label_authentication) },
       I18n.t("ldap_departments.synchronized_trees.plural")]
    )
  end
%>

<%= render(Primer::OpenProject::SubHeader.new) do |subheader|
      subheader.with_action_button(
        tag: :a,
        href: new_ldap_departments_synchronized_tree_path,
        scheme: :primary,
        leading_icon: :plus,
        disabled: !EnterpriseToken.allows_to?(:ldap_groups),
        label: I18n.t("ldap_departments.synchronized_trees.add_new")
      ) do
        I18n.t("ldap_departments.synchronized_trees.add_new")
      end
    end %>

<%= render EnterpriseEdition::BannerComponent.new(:ldap_groups, variant: :inline) %>

<div class="op-toast -info">
  <div class="op-toast--content">
    <strong><%= t("note") %></strong>
    <%= t("ldap_departments.synchronized_trees.help_text") %>
  </div>
</div>

<% if @trees.any? %>
  <table class="generic-table">
    <thead>
      <tr>
        <th><%= SynchronizedTree.human_attribute_name(:name) %></th>
        <th><%= SynchronizedTree.human_attribute_name(:ldap_auth_source) %></th>
        <th><%= SynchronizedTree.human_attribute_name(:base_dn) %></th>
        <th><%= t("ldap_departments.synchronized_departments.plural") %></th>
        <th><div class="generic-table--empty-header"></div></th>
      </tr>
    </thead>
    <tbody>
      <% @trees.each do |tree| %>
        <tr>
          <td><%= link_to tree.name, ldap_departments_synchronized_tree_path(tree_id: tree.id) %></td>
          <td><%= tree.ldap_auth_source&.name %></td>
          <td><%= tree.base_dn %></td>
          <td><%= tree.synchronized_departments.size %></td>
          <td class="buttons">
            <%= link_to op_icon("icon-edit"), edit_ldap_departments_synchronized_tree_path(tree_id: tree.id),
                        title: t(:button_edit) %>
            <%= link_to op_icon("icon-delete"), ldap_departments_synchronized_tree_path(tree_id: tree.id),
                        data: { turbo_method: :delete, turbo_confirm: t(:text_are_you_sure) },
                        title: t(:button_delete) %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <%= render Primer::Beta::Blankslate.new(border: true) do |blankslate|
        blankslate.with_visual_icon(icon: :organization)
        blankslate.with_heading(tag: :h2) { t("ldap_departments.synchronized_trees.blankslate.heading") }
        blankslate.with_description { t("ldap_departments.synchronized_trees.blankslate.description") }
        blankslate.with_primary_action(
          href: new_ldap_departments_synchronized_tree_path,
          disabled: !EnterpriseToken.allows_to?(:ldap_groups)
        ) do |button|
          button.with_leading_visual_icon(icon: :plus)
          t("ldap_departments.synchronized_trees.add_new")
        end
      end %>
<% end %>
